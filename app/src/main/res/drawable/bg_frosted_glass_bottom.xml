<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Top Shadow / Glow -->
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
            <solid android:color="#2A000000" />
        </shape>
    </item>

    <!-- Main Bottom Glass Panel -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FA090B11"
                android:endColor="#EC040508"
                android:angle="270" />
            <corners
                android:topLeftRadius="26dp"
                android:topRightRadius="26dp" />
            <stroke
                android:width="1.2dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>
</layer-list>
